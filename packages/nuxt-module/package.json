{
    "name": "@cjdevstudios/bumblevue-nuxt-module",
    "version": "1.0.0-beta.1",
    "author": "CJ Development Studios",
    "contributors": [
        {
            "name": "CJ Development Studios"
        },
        {
            "name": "PrimeTek Informatics"
        }
    ],
    "description": "Nuxt module for BumbleVue",
    "homepage": "https://bumblevue.org/",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/CJDevStudios/bumblevue.git",
        "directory": "packages/nuxt-module"
    },
    "bugs": {
        "url": "https://github.com/CJDevStudios/bumblevue/issues"
    },
    "keywords": [
        "vue",
        "vue.js",
        "vue3",
        "nuxt",
        "nuxt3",
        "primevue",
        "bumblevue"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./src/module.ts",
    "types": "./src/types.d.ts",
    "files": [
        "dist"
    ],
    "build": {
        "externals": [
            "@cjdevstudios/bumblevue",
            "@cjdevstudios/bumblevue-metadata",
            "@cjdevstudios/bumblevue-auto-import-resolver",
            "unplugin-vue-components",
            "@cjdevstudios/bumbleuix-utils",
            "@cjdevstudios/bumbleuix-utils/object",
            "@cjdevstudios/bumbleuix-utils/dom"
        ]
    },
    "publishConfig": {
        "main": "./dist/module.cjs",
        "types": "./dist/types.d.ts",
        "exports": {
            ".": {
                "types": "./dist/types.d.ts",
                "import": "./dist/module.mjs",
                "require": "./dist/module.cjs"
            }
        },
        "access": "public"
    },
    "scripts": {
        "build": "NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && pnpm run prepack",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "prepack": "nuxt-module-build build",
        "dev": "nuxi dev playground",
        "dev:build": "nuxi build playground",
        "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
        "dev:link": "pnpm link --global && npm link",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
    },
    "dependencies": {
        "@cjdevstudios/bumbleuix-styled": "catalog:",
        "@cjdevstudios/bumbleuix-utils": "catalog:",
        "@cjdevstudios/bumblevue": "workspace:*",
        "@cjdevstudios/bumblevue-auto-import-resolver": "workspace:*",
        "@cjdevstudios/bumblevue-forms": "workspace:*",
        "@cjdevstudios/bumblevue-metadata": "workspace:*",
        "@nuxt/kit": "^3",
        "pathe": "^1.1.2",
        "unplugin-vue-components": "28.4.1"
    },
    "devDependencies": {
        "@cjdevstudios/bumbleuix-themes": "catalog:",
        "@nuxt/devtools": "^2.1.0",
        "@nuxt/eslint-config": "^1.1.0",
        "@nuxt/module-builder": "^0.8.4",
        "@nuxt/schema": "^3",
        "@nuxt/test-utils": "^3",
        "@types/node": "latest",
        "changelogen": "^0.6.0",
        "nuxt": "catalog:app",
        "vitest": "^3.0.7",
        "vue-tsc": "~2.1.6"
    },
    "engines": {
        "node": ">=12.11.0"
    }
}
